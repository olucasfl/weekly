generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String
  emailVerified     Boolean            @default(false)
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?
  resetToken              String?   @unique
  resetTokenExpiry        DateTime?
  pendingEmail       String?
  pendingEmailToken  String?            @unique
  pendingEmailExpiry DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  categories        Category[]
  tasks             Task[]
  goals             Goal[]
  goalProgresses    GoalProgress[]
  completions       Completion[]
  pushSubscriptions PushSubscription[]
  notes             Note[]
  extraOccurrences  ExtraOccurrence[]
}

model Category {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  color  String
  tasks  Task[]
  goals  Goal[]

  @@index([userId])
}

model Task {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  type            String
  weekdays        Int[]
  date            String?
  startTime       String
  endTime         String?
  reminder        Boolean      @default(true)
  reminderMin     Int          @default(60)
  active          Boolean      @default(true)
  deletedAt       String?
  notes           String?      @default("")
  categoryId      String?
  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurrenceType  String       @default("weekly")
  endDate         String?
  biweeklyAnchor  String?
  monthlyDay      Int?
  monthlyWeekday  Int?
  monthlyWeek     Int?
  completions      Completion[]
  extraOccurrences ExtraOccurrence[]

  @@index([userId, type])
}

model ExtraOccurrence {
  id     String @id @default(cuid())
  userId String
  taskId String
  date   String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId, date])
  @@index([userId])
}

model Completion {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date      String
  done      Boolean @default(false)
  skipped   Boolean @default(false)

  @@unique([userId, taskId, date])
  @@index([userId, date])
}

model Goal {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  target     Int            @default(1)
  weekStart  String?        // null = recurring every week; ISO date = only for that week
  categoryId String?
  category   Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  progresses GoalProgress[]

  @@index([userId])
}

model GoalProgress {
  id        String @id @default(cuid())
  userId    String
  goalId    String
  weekStart String
  count     Int    @default(0)
  goal      Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId, weekStart])
  @@index([userId, weekStart])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}
