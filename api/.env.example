PORT=3333
HOST=0.0.0.0

# Supabase ou outro PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Gere valores aleatórios seguros (ex: openssl rand -hex 32)
JWT_SECRET=troque-por-valor-aleatorio-seguro
JWT_REFRESH_SECRET=troque-por-outro-valor-aleatorio-seguro

# URL do seu front na Vercel (sem barra no final)
# Para múltiplos origins, separe por vírgula
CORS_ORIGIN=https://seu-app.vercel.app

# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:seu@email.com
